# .env.example — machine-specific configuration
# Copy to .env and fill in values. .env is gitignored.

# Windows username (used in tool paths and log output)
WIN_USER=your_username

# Tool paths — defaults shown, override if your layout differs
FRST_PATH=%USERPROFILE%\Downloads\FRST64.exe
FIXLIST_PATH=%USERPROFILE%\Downloads\FIXLIST.txt
ADWCLEANER_PATH=%USERPROFILE%\Downloads\AdwCleaner.exe
HITMANPRO_PATH=C:\Program Files\HitmanPro\HitmanPro_x64.exe

# GitHub remote
GITHUB_REMOTE=https://github.com/jagp/claude-substrate-hygiene-suite
